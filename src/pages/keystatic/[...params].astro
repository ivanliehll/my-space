---
// 強制靜態導出
export const prerender = true;

// 由於不使用 Astro Integration，我們可以直接動態生成路由參數，讓靜態打包通過
export function getStaticPaths() {
  return [
    { params: { params: undefined } },
    { params: { params: 'posts' } },
  ];
}
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>奕和的發文基地 🚀</title>
    <link rel="stylesheet" href="https://unpkg.com/@keystatic/core/styles.css" />
</head>
<body style="margin: 0; background-color: #111;">
    <div id="keystatic-root"></div>

    <script>
        import { makePage } from '@keystatic/astro/ui';
        import config from '../../../keystatic.config';

        // 透過純前端 React 接管這個頁面，徹底避開 Astro 6 的編譯器限制
        const KeystaticPage = makePage(config);
        const root = document.getElementById('keystatic-root');
        if (root) {
            // 執行前端渲染
            import('react-dom/client').then(({ createRoot }) => {
                createRoot(root).render(KeystaticPage);
            });
        }
    </script>
</body>
</html>